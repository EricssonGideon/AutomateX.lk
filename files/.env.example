# ─── Database ───────────────────────────────────────────────────────────────
# Get your free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/automatex?retryWrites=true&w=majority

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000

# ─── Admin dashboard ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here
ADMIN_SECRET=your-random-secret-string-here
# Full URL to your deployed site (used in admin email link)
ADMIN_URL=https://your-app.onrender.com/admin.html

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Where admin notifications go
ADMIN_EMAIL=your@email.com

# Option A – Gmail (enable "App Passwords" in your Google account)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=AutomateX <your@gmail.com>

# Option B – SendGrid
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=apikey
# EMAIL_PASS=SG.your-sendgrid-api-key
# EMAIL_FROM=AutomateX <noreply@yourdomain.com>

# ─── Leave blank in development – Ethereal fake SMTP is used automatically ───
