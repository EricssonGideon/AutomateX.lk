# Local development defaults
PORT=5001
NODE_ENV=development

# Required for backend auth
MONGODB_URI=mongodb+srv://...
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=12h
ALLOWED_ORIGINS=http://localhost:5001,https://automatex.com
PUBLIC_APP_URL=https://automatex.com
CLIENT_DASHBOARD_URL=https://automatex.com/dashboard
PASSWORD_RESET_URL=https://automatex.com/reset-password

# File storage
# Local storage is for development only. Use STORAGE_DRIVER=s3 for staging and production.
STORAGE_DRIVER=local
# Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=
# Cloudflare R2: auto
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Leave empty for private backend-streamed downloads.
S3_PUBLIC_BASE_URL=
# Cloudflare R2: true for staging/production R2 buckets
S3_FORCE_PATH_STYLE=false

# Optional integrations
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=AutomateX <no-reply@automatex.com>
SUPPORT_EMAIL=support@automatex.com
OPENAI_API_KEY=sk_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_STANDARD_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
