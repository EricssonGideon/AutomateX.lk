{
  "name": "automatex-booking-platform",
  "version": "1.0.0",
  "description": "AutomateX full-stack booking website with Express and MongoDB",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:tailwind": "tailwindcss -c tailwind.config.js -i src/tailwind.css -o public/assets/css/tailwind.css --minify",
    "lint": "eslint .",
    "test": "node --test",
    "test:api": "node --test test/api/*.test.js",
    "check:storage": "node scripts/checkStorageConfig.js",
    "seed:admin": "node server/scripts/createAdmin.js",
    "reset:admin-password": "node server/scripts/resetAdminPassword.js"
  },
  "keywords": [
    "automatex",
    "express",
    "mongodb",
    "booking",
    "portfolio"
  ],
  "author": "AutomateX",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1060.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dompurify": "^3.4.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.1",
    "openai": "^6.35.0",
    "resend": "^6.12.2",
    "serverless-http": "^4.0.0",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "nodemon": "^3.1.4",
    "tailwindcss": "^3.4.17"
  }
}
